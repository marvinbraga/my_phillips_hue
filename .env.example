# ====================================
# Marvin Hue - Environment Configuration
# ====================================
# Copy this file to .env and fill in your values
# All settings can be overridden via environment variables

# ====================================
# Philips Hue Bridge Configuration
# ====================================

# IP address of your Philips Hue Bridge (REQUIRED)
# Find it in the Hue app or your router's DHCP leases
BRIDGE_IP=192.168.1.100

# Timeout in seconds for bridge operations (default: 10)
# Range: 1-60 seconds
BRIDGE_TIMEOUT=10


# ====================================
# API Configuration
# ====================================

# Optional API key for authentication (default: None)
# Leave empty for no authentication
API_KEY=

# CORS allowed origins (comma-separated, default: *)
# Examples:
#   - Development: *
#   - Production: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# API server host (default: 0.0.0.0)
# Use 127.0.0.1 to only allow local connections
API_HOST=0.0.0.0

# API server port (default: 5000)
# Range: 1-65535
API_PORT=5000


# ====================================
# Chat/AI Configuration
# ====================================

# Chat provider: openai, anthropic, xai, or groq (default: openai)
CHAT_PROVIDER=openai

# Model name for the selected provider
# OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo, etc.
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229, etc.
# xAI: grok-beta
# Groq: mixtral-8x7b-32768, llama2-70b-4096, etc.
CHAT_MODEL=gpt-4o-mini

# Temperature for chat generation (default: 0.7)
# Range: 0.0 (deterministic) to 2.0 (very creative)
CHAT_TEMPERATURE=0.7

# API Keys for chat providers (only one needed based on CHAT_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=


# ====================================
# File Paths Configuration
# ====================================

# Path to lighting configurations JSON (default: .res/setups.json)
SETUPS_FILE=.res/setups.json

# Path to light positions JSON for screen mirroring (default: .res/light_positions.json)
POSITIONS_FILE=.res/light_positions.json


# ====================================
# Logging Configuration
# ====================================

# Logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL (default: INFO)
# DEBUG: Detailed information, typically of interest only when diagnosing problems
# INFO: Confirmation that things are working as expected
# WARNING: An indication that something unexpected happened
# ERROR: A more serious problem that prevented a function from completing
# CRITICAL: A very serious error that may prevent the program from continuing
LOG_LEVEL=INFO

# Path to log file (default: logs/marvin_hue.log)
# The directory will be created automatically if it doesn't exist
LOG_FILE=logs/marvin_hue.log
